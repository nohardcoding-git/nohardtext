{
  "name": "@nohardtext/report-engine",
  "version": "0.1.0-rc.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nohardtext/domain": "workspace:*"
  },
  "description": "Reporting and summary engine for NoHardText.",
  "keywords": [
    "localization",
    "i18n",
    "reporting",
    "ci"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
