{
  "name": "@nohardtext/cli",
  "version": "0.1.0-rc.1",
  "private": true,
  "type": "module",
  "bin": {
    "nohardtext": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nohardtext/detect-engine": "workspace:*",
    "@nohardtext/domain": "workspace:*",
    "@nohardtext/report-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "description": "CLI for detecting hardcoded user-facing UI strings.",
  "keywords": [
    "localization",
    "i18n",
    "cli",
    "react",
    "typescript"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ]
}
